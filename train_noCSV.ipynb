    "        \n",
    "        # Flatten the output\n",
    "        Flatten(),\n",
    "        \n",
    "        # Fully connected layer\n",
    "        Dense(128, activation='relu'),\n",
    "        \n",
    "        # Output layer\n",
    "        Dense(num_classes, activation='softmax')\n",
    "])\n",
    "\n",
    "model = INCLUDE8_V2\n",
    "\n",
    "model.compile(optimizer='adam', loss='categorical_crossentropy', metrics=['accuracy'])\n",
    " \n",
    "model.build()\n",
    "model.summary()"
