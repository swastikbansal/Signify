    "INCLUDE8_V2 = keras.Sequential([        \n",
    "        Input(shape=input_shape),        \n",
    "        \n",
    "        # Bidirectional LSTM layers\n",
    "        Bidirectional(LSTM(64, return_sequences=True)),\n",
