# Environment configuration for Signify app
# Copy this to .env.local and adjust values for your environment

# Supabase Configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Security Settings
DEBUG_LOGS=false
CRASH_REPORTING=true

# Development vs Production flags
ENVIRONMENT=development

# Google Drive Configuration
# Pass the full service account JSON contents as a single-line string here
GOOGLE_DRIVE_SERVICE_ACCOUNT=''''''
GOOGLE_DRIVE_FOLDER_ID=

# Firebase Web Configuration (Optional - fallback defaults exist in code)
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_MEASUREMENT_ID=