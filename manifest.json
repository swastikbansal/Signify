{
  "manifest_version": 3,
  "name": "Signify - ISL Translator",
  "version": "1.0.2",
  "description": "Indian Sign Language translator for YouTube videos with 3D animated avatar powered by Supabase",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://youtube.com/*",
    "*://qqyqwtoxjhgashwxyidg.supabase.co/*",
    "*://cdn.jsdelivr.net/*",
    "*://*.supabase.co/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*", "*://youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html",
        "popup.js",
        "sidepanel.html",
        "sidepanel.js",
        "help.html",
        "three.min.js",
        "GLTFLoader.js",
        "OrbitControls.js",
        "supabase.js",
        "simple-test.js",
        "fallback-avatar.js",
        "animation/*.glb",
        "icons/signify.svg"
      ],
      "matches": ["*://www.youtube.com/*", "*://youtube.com/*"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Signify ISL Translator",
    "default_icon": {
      "16": "icons/signify-logo_16.png",
      "48": "icons/signify-logo_48.png",
      "128": "icons/signify-logo_128.png"
    }
  },
  "icons": {
    "16": "icons/signify-logo_16.png",
    "48": "icons/signify-logo_48.png",
    "128": "icons/signify-logo_128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}