{
  "manifest_version": 3,
  "name": "Signify-ISL YouTube Extension",
  "version": "1.0.0",
  "description": "View Indian Sign Language animations on any webpage",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Signify"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["three.min.js", "GLTFLoader.js", "OrbitControls.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["animation/*", "viewer.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
