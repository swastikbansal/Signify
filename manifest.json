{
  "manifest_version": 3,
  "name": "Signify-ISL Browser Extension",
  "version": "2.7.0",
  "description": "View Indian Sign Language animations on any webpage",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ISL Animation Viewer"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "three.min.js", "GLTFLoader.js", "OrbitControls.js", "supabase-config.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "viewer.html",
        "animation/default.glb",
        "animation/*.glb",
        "animation/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": [
    "https://*.supabase.co/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
